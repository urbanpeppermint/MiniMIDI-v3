  InputLines:
    - '// @input AssignableType djMidiManager {"hint":"When affectLyriaPadPitch is ON: DJMidiManager used to retune the pad aligned with the bar index."}'
    - '// @input bool affectLyriaPadPitch {"hint":"If ON, bar index maps to pad[i] and setSpectrumPitchSemitones applies. Default OFF — spectrum is overlay navigation only."}'
    - '// @input Component.ScriptComponent spectrumFeatureToggle {"hint":"Optional: SIK ToggleButton — when ON, pinch navigation runs. Leave empty to always allow pinch (single mode)."}'
    - '// @input SceneObject spectrumRoot {"hint":"World origin of the spectrum disc; local XZ plane is used for angle + radius."}'
    - '// @input SceneObject barMarkersParent {"hint":"Optional: parent whose ordered children are bar meshes (0 = first bar). Highlight scales selected bar."}'
    - '// @input SceneObject spectrumVisualsRoot {"hint":"Optional: hide this object (and children) when the feature toggle is OFF."}'
    - '// @input float barCount = 9 {"hint":"Number of spectrum bars / note slots around the ring (visual count; independent of Lyria pad count unless affectLyriaPadPitch is ON)."}'
    - '// @input float pinchStartMaxRadiusFromCenter = 14 {"hint":"Max distance from spectrum center (cm) for pinch midpoint to count as starting the gesture."}'
    - '// @input float spectrumInnerRadius = 10 {"hint":"Inner radius of the spectrum ring (cm) — at this radius radial semitone offset is 0."}'
    - '// @input float spectrumOuterRadius = 38 {"hint":"Outer radius of the spectrum ring (cm)."}'
    - "// @input float angleOffsetRad {\"hint\":\"Radians added to atan2 before mapping angle → bar (rotate which note slot is at 12 o'clock).\"}"
    - '// @input float spectrumSemitoneStepPerBar = 1 {"hint":"If bar semitones CSV is empty: semitone = barIndex × step + rootOffset."}'
    - '// @input float spectrumRootSemitoneOffset {"hint":"Added to each bar’s discrete semitone when CSV is empty."}'
    - '// @input string spectrumBarSemitonesCsv {"hint":"Optional: comma-separated semitones per bar, e.g. 0,2,4,5,7,9,11,12,14 — overrides step×index if enough values."}'
    - '// @input float spectrumRadialSemitoneRange = 4 {"hint":"Semitones added from inner→outer radius (theremin sweep)."}'
    - '// @input float pinchStrengthThreshold = 0.55 {"hint":"Min pinch strength (0–1) to read the gesture."}'
    - '// @input bool dominantHandOnly = true {"hint":"Use dominant hand only; if false, either hand can drive (first valid pinch wins)."}'
    - '// @input float barHighlightScale = 1.18 {"hint":"Scale multiplier for the highlighted bar mesh."}'
    - '// @input float applyThrottleSec = 0.085 {"hint":"When affectLyriaPadPitch: seconds between resample applies. Also throttles debug prints."}'
    - '// @input bool debugLog {"hint":"Print mapping / state changes."}'
