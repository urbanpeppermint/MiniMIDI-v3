    - '// @input SceneObject[] spectrumBars = {} {"hint":"Bar roots in ring order (spectrum note slots / SpecBars; count need not match Lyria pads)."}'
    - '// @input SceneObject spectrumBarsParent {"hint":"When set and has children, their hierarchy order drives layout (recommended: SpectrumRing). Otherwise `spectrumBars` is used."}'
